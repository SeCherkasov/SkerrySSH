<?xml version="1.0" encoding="UTF-8"?>
<!-- AppStream metadata for the Flatpak build. id matches the .desktop basename and the
     reverse-DNS app-id used throughout (Android applicationId app.skerry). -->
<component type="desktop-application">
  <id>app.skerry.Skerry</id>

  <name>Skerry</name>
  <summary>Cross-platform SSH client with a single core</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <developer id="app.skerry">
    <name>Sergey Cherkasov</name>
  </developer>

  <description>
    <p>
      Skerry is an open-source SSH client built on a single Kotlin Multiplatform core with
      a Compose Multiplatform UI, sharing one codebase across Desktop and Android.
    </p>
    <p>Features:</p>
    <ul>
      <li>SSH (sshj + BouncyCastle) and SSH certificates</li>
      <li>SFTP with a dual-pane commander</li>
      <li>Port forwarding: local (-L), remote (-R), and dynamic/SOCKS (-D)</li>
      <li>Telnet and serial connections</li>
      <li>Custom terminal emulation: VT line-drawing, Unicode, SGR, OSC 8/4/52, bracketed paste</li>
      <li>Session tabs with split view, SSH auto-reconnect, and live host metrics</li>
      <li>Zero-knowledge vault (XChaCha20-Poly1305): keys, passwords, identities, certificates</li>
      <li>Optional self-hosted, zero-knowledge sync</li>
      <li>Optional AI assistant with per-host policies, including a fully local on-device model</li>
    </ul>
  </description>

  <launchable type="desktop-id">app.skerry.Skerry.desktop</launchable>

  <url type="homepage">https://github.com/SeCherkasov/SkerrySSH</url>
  <url type="bugtracker">https://github.com/SeCherkasov/SkerrySSH/issues</url>
  <url type="vcs-browser">https://github.com/SeCherkasov/SkerrySSH</url>

  <screenshots>
