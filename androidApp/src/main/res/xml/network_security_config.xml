<?xml version="1.0" encoding="utf-8"?>
<!--
  Allow cleartext (HTTP) for the self-hosted sync server: the user runs it themselves, often on a
  local network without TLS. The payload is E2E-encrypted anyway (zero-knowledge), SRP is safe over
  cleartext, and the metadata is open by design (the Vaultwarden model, docs/skerry-sync-design.md).
  Whoever sets up HTTPS points at https:// and gets an encrypted transport with no config changes.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
